# Trigger.dev secret key — used SERVER-SIDE ONLY in /api/qualify route
# Never prefix with NEXT_PUBLIC_ — must stay out of the browser bundle
TRIGGER_SECRET_KEY=tr_dev_ASHhZO2CyqUC3d9Zh8pX

# Trigger.dev project reference — safe to expose (no NEXT_PUBLIC_ needed for server routes)
# Get from: Trigger.dev dashboard → Project Settings
NEXT_PUBLIC_TRIGGER_PROJECT_REF=proj_wwlclvzimthdptrduwlg

# Supabase — get from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Supabase service role key — SERVER-SIDE ONLY, never expose to browser
# Used in the Stripe webhook handler to write subscription state without RLS restrictions
# Get from: Supabase dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Stripe — SERVER-SIDE ONLY (no NEXT_PUBLIC_ prefix)
# Get from: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
# Get from: Stripe Dashboard → Developers → Webhooks → signing secret
# For local dev, use: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: Stripe Dashboard → Products → create a $29/month recurring price → copy price ID
STRIPE_PRICE_ID=price_...

# Stripe publishable key — browser-safe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# App base URL — used for Stripe redirect URLs (no trailing slash)
# Set to your Vercel URL in production (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000
